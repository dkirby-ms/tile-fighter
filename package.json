{
  "name": "tile-fighter",
  "version": "0.1.0",
  "private": true,
  "packageManager": "npm@10.9.0",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "concurrently -k -n server,web -c cyan,green \"npm run -w @game/server dev\" \"npm run -w @game/web dev -- --host\"",
    "dev:server": "npm run -w @game/server dev",
    "dev:web": "npm run -w @game/web dev -- --host",
    "build": "tsc -b",
    "lint": "npm run --workspaces lint",
    "test": "npm run --workspaces test",
    "version-packages": "changeset version",
    "release": "changeset publish",
    "changeset-status": "changeset status"
  },
  "devDependencies": {
    "@changesets/cli": "^2.29.6",
    "@eslint/js": "^9.39.0",
    "@types/node": "^22.10.2",
    "@typescript-eslint/eslint-plugin": "^8.62.0",
    "@typescript-eslint/parser": "^8.62.0",
    "concurrently": "^10.0.3",
    "eslint": "^9.39.0",
    "globals": "^15.15.0",
    "typescript": "^5.6.3",
    "vitest": "^4.1.9"
  }
}
