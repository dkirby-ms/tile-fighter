{
  "name": "@game/server",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "dev": "tsx src/index.ts",
    "build": "tsc -b",
    "lint": "eslint src tests --ext .ts",
    "test": "vitest run",
    "test:load": "tsx tests/load/room-join-load.ts",
    "migrate:up": "node-pg-migrate -m src/persistence/migrations up",
    "migrate:down": "node-pg-migrate -m src/persistence/migrations down"
  },
  "dependencies": {
    "@colyseus/schema": "^4.0.7",
    "@colyseus/ws-transport": "~0.17.13",
    "@game/shared-auth": "file:../../packages/shared-auth",
    "@game/shared-persistence": "file:../../packages/shared-persistence",
    "@game/shared-types": "file:../../packages/shared-types",
    "colyseus": "0.17.10",
    "dotenv": "^17.4.2",
    "express": "^4.19.2",
    "kysely": "^0.28.8",
    "pg": "^8.13.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^22.10.2",
    "@types/pg": "^8.15.5",
    "@types/supertest": "^6.0.2",
    "@colyseus/sdk": "0.17.43",
    "node-pg-migrate": "^8.0.4",
    "supertest": "^7.1.1",
    "tsx": "^4.19.2"
  }
}
