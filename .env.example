NODE_ENV=development
PORT=3000
DATABASE_URL=postgres://postgres:postgres@localhost:5432/tile_fighter
ENTRA_ISSUER=https://exampletenant.ciamlogin.com/exampletenant.onmicrosoft.com/v2.0
ENTRA_AUDIENCE=api://tile-fighter-server
ENTRA_JWKS_URL=https://exampletenant.ciamlogin.com/exampletenant.onmicrosoft.com/discovery/v2.0/keys
ENTRA_TOKEN_VERSION=2.0
ENTRA_TENANT_ID=00000000-0000-0000-0000-000000000000
ENTRA_CLIENT_ID=00000000-0000-0000-0000-000000000000
VITE_APP_API_BASE_URL=http://localhost:3000
VITE_APP_ROOM_WS_URL=ws://localhost:3000
VITE_APP_MSAL_AUTHORITY=https://exampletenant.ciamlogin.com/exampletenant.onmicrosoft.com
VITE_APP_MSAL_CLIENT_ID=00000000-0000-0000-0000-000000000000
VITE_APP_MSAL_REDIRECT_URI=http://localhost:5173
VITE_APP_MSAL_KNOWN_AUTHORITY=exampletenant.ciamlogin.com
VITE_APP_MSAL_API_SCOPE=api://tile-fighter-server/access_as_user
TENANT_MODE=single
ALLOWED_TENANT_IDS=
DENIED_TENANT_IDS=
